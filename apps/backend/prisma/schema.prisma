generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === AUTHENTICATION & USERS ===

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  avatarUrl    String?
  role         UserRole
  isActive     Boolean   @default(true)
  isVerified   Boolean   @default(false)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  issues              Issue[]              @relation("IssueReporter")
  assignedIssues      Issue[]              @relation("IssueAssignee")
  comments            Comment[]
  votes               Vote[]
  surveys             Survey[]
  surveyResponses     SurveyResponse[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  announcements       Announcement[]
  events              Event[]
  eventRSVPs          EventRSVP[]
  sentMessages        Message[]            @relation("MessageSender")
  receivedMessages    Message[]            @relation("MessageReceiver")
  resolutions         Resolution[]         @relation("ResolutionProposer")
  referendumsCreated  Referendum[]         @relation("ReferendumCreator")
  referendumVotes     ReferendumVote[]    @relation("ReferendumVoter")
  refreshTokens       RefreshToken[]
  forums              Forum[]
  forumPosts          ForumPost[]
  passwordResetTokens PasswordResetToken[]

  // === Feature additions (10-feature sweep) ===
  issueSubscriptions     IssueSubscription[]
  shareLinksCreated      IssueShareLink[]         @relation("ShareLinkCreator")
  savedSearches          SavedSearch[]
  notificationPrefs      NotificationPreference[]
  internalNotes          InternalNote[]
  assignmentsReceived    IssueAssignment[]        @relation("AssignmentAssignee")
  assignmentsPerformed   IssueAssignment[]        @relation("AssignmentAssigner")
  unassignmentsPerformed IssueAssignment[]        @relation("AssignmentUnassigner")

  // Ward relationship (many users in one ward)
  wardId String?
  ward   Ward?   @relation("WardResident", fields: [wardId], references: [id])

  // Ward representative (one-to-one: a ward has one rep)
  representativeOf Ward? @relation("WardRepresentative")

  // Department staff relationship (many staff in one dept)
  departmentId String?
  department   Department? @relation("DepartmentStaff", fields: [departmentId], references: [id])

  // Department head (one-to-one: user heads one dept)
  managedDepartment Department? @relation("DepartmentHead")

  // Documents uploaded by this user (admin / staff)
  documentsUploaded Document[]
}

enum UserRole {
  SUPER_ADMIN
  MAYOR
  DEPARTMENT_HEAD
  COUNCIL_MEMBER
  STAFF
  WARD_REP
  CITIZEN
  VOLUNTEER
  AUDITOR
  MEDIA
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// === GEOGRAPHIC STRUCTURE ===

model Ward {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  boundary    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Ward representative (one-to-one)
  representativeId String? @unique
  representative   User?   @relation("WardRepresentative", fields: [representativeId], references: [id])

  // Residents (one-to-many)
  users       User[]           @relation("WardResident")
  issues      Issue[]
  departments DepartmentWard[]
  digests     WardDigest[]
}

model Department {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  budget      Decimal? @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Department head (one-to-one via headId)
  headId String? @unique
  head   User?   @relation("DepartmentHead", fields: [headId], references: [id])

  // Staff members (one-to-many)
  staff User[] @relation("DepartmentStaff")

  issues Issue[]
  wards  DepartmentWard[]
}

model DepartmentWard {
  id           String     @id @default(uuid())
  departmentId String
  wardId       String
  department   Department @relation(fields: [departmentId], references: [id])
  ward         Ward       @relation(fields: [wardId], references: [id])

  @@unique([departmentId, wardId])
}

// === ISSUES & FEEDBACK ===

model Issue {
  id                    String        @id @default(uuid())
  title                 String
  description           String
  category              IssueCategory
  status                IssueStatus   @default(SUBMITTED)
  priority              Int?
  priorityJustification String?
  location              String
  latitude              Decimal?      @db.Decimal(9, 6)
  longitude             Decimal?      @db.Decimal(9, 6)
  /// PostGIS geometry column managed via raw SQL (Prisma doesn't
  /// support GEOMETRY natively). SRID 4326 = WGS 84, the same
  /// coordinate system as latitude/longitude. The backfill in
  /// `20260617000000_postgis_spatial/migration.sql` populates this
  /// from the existing latitude/longitude columns; the spatial
  /// service keeps it in sync on every issue create/update.
  locationGeom          Unsupported("geometry(Point, 4326)")?
  upvotes               Int           @default(0)
  viewCount             Int           @default(0)
  isPublic              Boolean       @default(true)
  reporterId            String
  reporter              User          @relation("IssueReporter", fields: [reporterId], references: [id])
  assigneeId            String?
  assignee              User?         @relation("IssueAssignee", fields: [assigneeId], references: [id])
  departmentId          String?
  department            Department?   @relation(fields: [departmentId], references: [id])
  wardId                String?
  ward                  Ward?         @relation(fields: [wardId], references: [id])
  /// When set, this issue is marked as a duplicate of another report.
  duplicateOfId         String?
  duplicateOf           Issue?        @relation("IssueDuplicates", fields: [duplicateOfId], references: [id], onDelete: SetNull)
  duplicates            Issue[]       @relation("IssueDuplicates")
  aiCategory            String?
  aiSentiment           String?
  /// Detected primary language of the citizen report ('en' | 'el').
  contentLocale         String?
  titleEn               String?
  titleEl               String?
  descriptionEn         String?
  descriptionEl         String?
  resolvedAt            DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  comments      Comment[]
  votes         Vote[]
  attachments   Attachment[]
  statusHistory StatusHistory[]
  tags          IssueTag[]

  // === Feature additions (10-feature sweep) ===
  subscriptions     IssueSubscription[]
  shareLinks        IssueShareLink[]
  internalNotes     InternalNote[]
  slaTracking       SlaTracking?
  assignmentHistory IssueAssignment[]

  // === RAG (pgvector) — one row per issue ===
  embedding IssueEmbedding?
}

enum IssueCategory {
  INFRASTRUCTURE
  PUBLIC_SAFETY
  SANITATION
  UTILITIES
  HOUSING
  ENVIRONMENT
  TRANSPORTATION
  EDUCATION
  HEALTH
  OTHER
}

enum IssueStatus {
  SUBMITTED
  ACKNOWLEDGED
  IN_PROGRESS
  PENDING_REVIEW
  RESOLVED
  VERIFIED
  REJECTED
  REOPENED
}

// === VOTING ===

model Vote {
  id        String   @id @default(uuid())
  value     Int
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  issueId   String?
  issue     Issue?   @relation(fields: [issueId], references: [id])
  surveyId  String?
  survey    Survey?  @relation(fields: [surveyId], references: [id])
  pollId    String?
  poll      Poll?    @relation(fields: [pollId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, issueId])
  @@unique([userId, surveyId])
  @@unique([userId, pollId])
}

// === COMMENTS ===

model Comment {
  id        String    @id @default(uuid())
  content   String
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  issueId   String
  issue     Issue     @relation(fields: [issueId], references: [id])
  parentId  String?
  parent    Comment?  @relation("CommentThread", fields: [parentId], references: [id])
  children  Comment[] @relation("CommentThread")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// === FORUMS ===

model Forum {
  id          String      @id @default(uuid())
  title       String
  description String?
  creatorId   String
  creator     User        @relation(fields: [creatorId], references: [id])
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  posts       ForumPost[]
}

model ForumPost {
  id        String   @id @default(uuid())
  forumId   String
  forum     Forum    @relation(fields: [forumId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  /// AI moderation flag (set asynchronously after post create).
  moderationFlag       Boolean  @default(false)
  moderationSeverity   String?
  moderationReason     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// === SURVEYS & POLLS ===

model Survey {
  id          String    @id @default(uuid())
  title       String
  description String?
  creatorId   String
  creator     User      @relation(fields: [creatorId], references: [id])
  isActive    Boolean   @default(true)
  closesAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  questions SurveyQuestion[]
  responses SurveyResponse[]
  votes     Vote[]
}

model SurveyQuestion {
  id       String @id @default(uuid())
  surveyId String
  survey   Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  text     String
  type     String
  options  Json?
  order    Int
}

model SurveyResponse {
  id        String   @id @default(uuid())
  surveyId  String
  survey    Survey   @relation(fields: [surveyId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  answers   Json
  createdAt DateTime @default(now())
}

model Poll {
  id          String    @id @default(uuid())
  title       String
  description String?
  creatorId   String
  isActive    Boolean   @default(true)
  closesAt    DateTime?
  createdAt   DateTime  @default(now())

  options PollOption[]
  votes   Vote[]
}

model PollOption {
  id     String @id @default(uuid())
  pollId String
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  text   String
  votes  Int    @default(0)
}

// === NOTIFICATIONS ===

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// === AUDIT LOG ===

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String
  oldValues Json?
  newValues Json?
  ipAddress String?
  createdAt DateTime @default(now())
}

// === ATTACHMENTS ===

model Attachment {
  id         String   @id @default(uuid())
  fileName   String
  fileUrl    String
  fileSize   Int
  mimeType   String
  issueId    String
  issue      Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  uploadedBy String
  createdAt  DateTime @default(now())
}

// === ANNOUNCEMENTS ===

model Announcement {
  id          String    @id @default(uuid())
  title       String
  content     String
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  isPinned    Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// === EVENTS ===

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  location    String?
  startTime   DateTime
  endTime     DateTime
  creatorId   String
  creator     User     @relation(fields: [creatorId], references: [id])
  type        String
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())

  rsvps EventRSVP[]
}

model EventRSVP {
  id      String @id @default(uuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  status  String

  @@unique([eventId, userId])
}

// === MESSAGING ===

model Message {
  id         String   @id @default(uuid())
  content    String
  senderId   String
  sender     User     @relation("MessageSender", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("MessageReceiver", fields: [receiverId], references: [id])
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// === RESOLUTIONS ===

model Resolution {
  id           String    @id @default(uuid())
  title        String
  description  String
  issueId      String?
  proposedById String
  proposedBy   User      @relation("ResolutionProposer", fields: [proposedById], references: [id])
  status       String    @default("DRAFT")
  votesFor     Int       @default(0)
  votesAgainst Int       @default(0)
  votedByIds   String[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  decidedAt    DateTime?
}

// ====================================================================
// Phase D1 — Referendum tracker (distinct from Resolution: a public
// ballot on a yes/no/abstain question, with a participation threshold
// and a pass threshold. Multiple users can vote; status transitions
// follow DRAFT -> OPEN -> CLOSED -> PASSED|REJECTED|CANCELLED.)
// ====================================================================

enum ReferendumStatus {
  DRAFT
  OPEN
  CLOSED
  PASSED
  REJECTED
  CANCELLED
}

enum ReferendumChoice {
  YES
  NO
  ABSTAIN
}

model Referendum {
  id              String           @id @default(uuid())
  title           String
  description     String
  /// The actual question / text on the ballot. May be longer than `description`.
  body            String
  status          ReferendumStatus @default(DRAFT)
  createdById     String
  createdBy       User             @relation("ReferendumCreator", fields: [createdById], references: [id])
  /// When voting opens (inclusive). Required before the status can flip to OPEN.
  opensAt         DateTime
  /// When voting closes (exclusive). Required before the status can flip to OPEN.
  closesAt        DateTime
  /// Fraction of YES+NO votes that must be YES for the referendum to pass.
  /// Default 0.5 (simple majority). Range 0 < passThreshold <= 1.
  passThreshold   Float            @default(0.5)
  /// Minimum total votes required for the result to be binding.
  /// Below this number the referendum is recorded as INCONCLUSIVE even
  /// if the yes-ratio would otherwise have passed.
  minParticipation Int             @default(0)
  /// Roles allowed to vote on this referendum. Empty array = any authenticated
  /// user. Otherwise the voter must have one of these roles.
  eligibleRoles   String[]         @default([])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  /// When the result was finalised (status flipped to PASSED/REJECTED).
  decidedAt       DateTime?
  /// Cached tallies for fast reads. Kept in sync inside the vote transaction.
  yesCount        Int              @default(0)
  noCount         Int              @default(0)
  abstainCount    Int              @default(0)
  totalVotes      Int              @default(0)

  votes           ReferendumVote[]

  @@index([status])
  @@index([closesAt])
}

model ReferendumVote {
  id            String           @id @default(uuid())
  referendumId  String
  referendum    Referendum       @relation(fields: [referendumId], references: [id], onDelete: Cascade)
  userId        String
  user          User             @relation("ReferendumVoter", fields: [userId], references: [id], onDelete: Cascade)
  choice        ReferendumChoice
  createdAt     DateTime         @default(now())

  @@unique([referendumId, userId])
  @@index([referendumId])
  @@index([userId])
}

// === TAGS ===

model IssueTag {
  id      String @id @default(uuid())
  issueId String
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  tag     String

  @@unique([issueId, tag])
}

// === STATUS HISTORY ===

model StatusHistory {
  id        String   @id @default(uuid())
  issueId   String
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  oldStatus String?
  newStatus String
  changedBy String
  note      String?
  createdAt DateTime @default(now())
}

// =====================================================
// === 10-Feature Sweep — Engagement / Workflow / Analytics
// =====================================================

// --- 1. Issue subscriptions (citizen follow) ---
model IssueSubscription {
  id        String   @id @default(uuid())
  issueId   String
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([issueId, userId])
  @@index([userId])
}

// --- 2. Issue sharing (public share token) ---
model IssueShareLink {
  id          String    @id @default(uuid())
  issueId     String
  issue       Issue     @relation(fields: [issueId], references: [id], onDelete: Cascade)
  token       String    @unique
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  createdById String
  createdBy   User      @relation("ShareLinkCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([createdById])
}

// --- 3. Saved searches (issue filter combos) ---
model SavedSearch {
  id            String                @id @default(uuid())
  userId        String
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  filters       Json
  /// Semantic query text for AI alert matching (from filters.search).
  queryText     String?
  alertsEnabled Boolean               @default(true)
  createdAt     DateTime              @default(now())
  embedding     SavedSearchEmbedding?
  alerts        SavedSearchAlert[]

  @@index([userId])
}

/// Embedding for saved-search semantic alert matching.
model SavedSearchEmbedding {
  id            String      @id @default(uuid())
  savedSearchId String      @unique
  savedSearch   SavedSearch @relation(fields: [savedSearchId], references: [id], onDelete: Cascade)
  embedding     Unsupported("vector(768)")?
  contentHash   String
  generatedAt   DateTime    @default(now())
}

/// Dedupes saved-search alert notifications per issue.
model SavedSearchAlert {
  id            String      @id @default(uuid())
  savedSearchId String
  savedSearch   SavedSearch @relation(fields: [savedSearchId], references: [id], onDelete: Cascade)
  issueId       String
  score         Float
  createdAt     DateTime    @default(now())

  @@unique([savedSearchId, issueId])
  @@index([savedSearchId])
}

// --- 4. Notification preferences (per-channel opt-in) ---
model NotificationPreference {
  id      String  @id @default(uuid())
  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel String // 'inApp' | 'email' | 'push'
  type    String // 'ISSUE_UPDATE' | 'COMMENT' | 'ANNOUNCEMENT' | 'EVENT' | etc.
  enabled Boolean @default(true)

  @@unique([userId, channel, type])
  @@index([userId])
}

// --- 5. Internal notes on issues (staff-only) ---
model InternalNote {
  id        String   @id @default(uuid())
  issueId   String
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([issueId])
}

// --- 6. SLA tracking (response/resolution timer) ---
model SlaTracking {
  id              String    @id @default(uuid())
  issueId         String    @unique
  issue           Issue     @relation(fields: [issueId], references: [id], onDelete: Cascade)
  priority        String
  dueAt           DateTime
  firstResponseAt DateTime?
  resolvedAt      DateTime?
  breached        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([breached, dueAt])
}

// --- 7. Assignment history (audit trail of who was assigned what and when) ---
model IssueAssignment {
  id             String    @id @default(uuid())
  issueId        String
  issue          Issue     @relation(fields: [issueId], references: [id], onDelete: Cascade)
  assigneeId     String?
  assignee       User?     @relation("AssignmentAssignee", fields: [assigneeId], references: [id])
  assignedById   String
  assignedBy     User      @relation("AssignmentAssigner", fields: [assignedById], references: [id])
  unassignedById String?
  unassignedBy   User?     @relation("AssignmentUnassigner", fields: [unassignedById], references: [id])
  assignedAt     DateTime  @default(now())
  unassignedAt   DateTime?
  reason         String?

  @@index([issueId, assignedAt])
}

// =====================================================
// === RAG / Vector store (issue-level embeddings)
// =====================================================

/// One embedding per issue, used for semantic duplicate detection and
/// "smart search". The `embedding` column is managed via raw SQL because
/// Prisma does not (yet) understand pgvector — dimension is 768
/// (nomic-embed-text via local Ollama). If you swap the embedding model,
/// the migration that creates this column (and the ivfflat index) must
/// be updated and the data re-embedded.
model IssueEmbedding {
  id          String                       @id @default(uuid())
  /// FK to Issue. One embedding per issue — enforced by @unique.
  issueId     String                       @unique
  issue       Issue                        @relation(fields: [issueId], references: [id], onDelete: Cascade)
  /// 768-dim vector.
  embedding   Unsupported("vector(768)")?
  /// Hash of the (title + description) content. Used to skip re-embedding
  /// when an issue is updated but the text hasn't materially changed.
  contentHash String
  /// Which embedding model produced this vector. Defaults to the value of
  /// `EMBED_MODEL` env var, which the migration runner will set.
  model       String                       @default("nomic-embed-text")
  /// When the embedding was last generated.
  generatedAt DateTime                     @default(now())

  @@index([issueId])
}

// =====================================================
// === RAG / Vector store (municipal legislation)
// =====================================================

/// Parent record for a piece of legislation, a decision, or any document we
/// want to make searchable for the AI assistant. Uploaded by an admin, split
/// into `DocumentChunk` rows for vector retrieval.
model Document {
  id           String   @id @default(uuid())
  title        String
  /// "ORDINANCE" | "DECISION" | "REGULATION" | "GUIDE" | "OTHER"
  type         String
  /// Where this document came from (URL, file name, manual entry).
  source       String
  description  String?
  /// Optional issue date — free text because documents come from many sources.
  documentDate String?
  /// Hash of the full text content. Re-ingesting the same file becomes a
  /// no-op (lets the worker be safely retried).
  contentHash  String   @unique
  /// Total character count after normalization, useful for diagnostics.
  charCount    Int      @default(0)
  /// Number of chunks the document was split into.
  chunkCount   Int      @default(0)
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  chunks DocumentChunk[]

  @@index([type])
  @@index([createdAt])
}

/// A chunk of a `Document` with its embedding. The `embedding` column is
/// managed via raw SQL because Prisma does not (yet) understand pgvector.
/// Dimension is 768 (nomic-embed-text, served by local Ollama). If you
/// swap the embedding model, the migration that creates this column
/// (and the ivfflat index) must be updated.
model DocumentChunk {
  id         String                       @id @default(uuid())
  documentId String
  document   Document                     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  /// 0-based position of this chunk inside the document.
  chunkIndex Int
  /// The actual text. Trimmed to roughly 500 tokens.
  content    String
  /// 768-dim vector produced by the embedding model. Stored as a raw
  /// pgvector column; queries use `$queryRaw`.
  embedding  Unsupported("vector(768)")?
  /// Optional free-form metadata (page number, section heading, etc.).
  metadata   Json?
  createdAt  DateTime                     @default(now())

  @@unique([documentId, chunkIndex])
  @@index([documentId])
}

// =====================================================
// === Weekly executive summary (Friday cron job)
// =====================================================

/// One per week. Generated by the Friday cron job (and on-demand from the
/// mayor dashboard). Content is the full AI-produced briefing; the
/// `highlights` JSON is a structured summary that the dashboard renders
/// above the prose.
model WeeklySummary {
  id          String   @id @default(uuid())
  /// ISO week key like "2026-W24" — used for idempotency so the cron
  /// never produces two summaries for the same week.
  weekKey     String   @unique
  /// Inclusive start (Monday) of the reporting week.
  weekStart   DateTime
  /// Inclusive end (Sunday) of the reporting week.
  weekEnd     DateTime
  /// Pre-aggregated numbers (total, open, resolved, byCategory, etc.).
  stats       Json
  /// { title, body }[] produced by the AI; rendered as bullet cards.
  highlights  Json
  /// Full prose briefing from the LLM.
  body        String
  /// Optional reference to the issues touched on (IDs).
  issueIds    String[]
  generatedAt DateTime @default(now())
  /// "AUTO" (cron) or "MANUAL" (button click on mayor dashboard).
  source      String   @default("AUTO")
  createdAt   DateTime @default(now())

  @@index([weekStart])
}

/// Daily AI digest for ward representatives — one row per ward per day.
model WardDigest {
  id          String   @id @default(uuid())
  wardId      String
  ward        Ward     @relation(fields: [wardId], references: [id], onDelete: Cascade)
  /// ISO date key "YYYY-MM-DD" for idempotency.
  dateKey     String
  body        String
  issueCount  Int      @default(0)
  issueIds    String[]
  generatedAt DateTime @default(now())
  source      String   @default("AUTO")

  @@unique([wardId, dateKey])
  @@index([dateKey])
}

/// Monthly AI demand forecast narrative for the mayor dashboard.
model SeasonalForecast {
  id          String   @id @default(uuid())
  /// Month key "YYYY-MM" for idempotency.
  monthKey    String   @unique
  stats       Json
  narrative   String
  generatedAt DateTime @default(now())
  source      String   @default("AUTO")
}

// =====================================================
// === Citizen FAQ knowledge base (Phase 3 AI)
// =====================================================

/// Auto-generated Q&A from resolved issues. Included in hybrid RAG.
model FaqEntry {
  id             String     @id @default(uuid())
  question       String
  answer         String
  category       String?
  sourceIssueIds String[]
  contentHash    String     @unique
  published      Boolean    @default(true)
  /// ISO week key for idempotent weekly generation.
  weekKey        String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  chunks         FaqChunk[]

  @@index([published])
  @@index([category])
  @@index([weekKey])
}

model FaqChunk {
  id         String                       @id @default(uuid())
  faqEntryId String
  faqEntry   FaqEntry                     @relation(fields: [faqEntryId], references: [id], onDelete: Cascade)
  chunkIndex Int
  content    String
  embedding  Unsupported("vector(768)")?
  createdAt  DateTime                     @default(now())

  @@unique([faqEntryId, chunkIndex])
  @@index([faqEntryId])
}
